---
import Button from './ui/Button.astro';
import { asset } from '../lib/asset.ts';
---

<footer class="footer">
  <div class="container">
    <div class="footer__cta" data-reveal>
      <div>
        <h2 class="footer__title">¿Representa a una misión diplomática o club?</h2>
        <p class="footer__lead">
          Iniciemos una conversación técnica sobre un acuerdo marco para el ciclo 2026.
        </p>
      </div>
      <div class="footer__cta-actions">
        <Button variant="gold" size="lg" data-open-contact>Solicitar convenio</Button>
      </div>
    </div>

    <div class="footer__bottom">
      <div class="footer__brand">
        <img src={asset('logo/cadd-emblem.svg')} width="56" height="56" alt="" />
        <div class="footer__brand-text">
          <span class="footer__brand-name">Consejo Argentino<br />de Diplomacia Deportiva</span>
          <span class="footer__brand-tag">Nexo institucional · técnico · neutral</span>
        </div>
      </div>
      <span class="footer__est">EST · 2026 · BUENOS AIRES, ARGENTINA</span>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--midnight-900);
    padding: 72px 0 40px;
  }

  .footer__cta {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 40px;
    align-items: center;
    padding-bottom: 48px;
    border-bottom: 1px solid var(--border-on-brand);
  }
  .footer__title {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: 34px;
    line-height: 1.1;
    color: var(--paper-100);
    margin: 0;
  }
  .footer__lead {
    font-size: 17px;
    line-height: 1.6;
    color: var(--text-on-brand-muted);
    margin-top: 12px;
    max-width: 520px;
  }
  .footer__cta-actions {
    display: flex;
    gap: 12px;
    justify-content: flex-end;
  }

  .footer__bottom {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 36px;
  }
  .footer__brand {
    display: inline-flex;
    align-items: center;
    gap: 14px;
  }
  .footer__brand-text {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .footer__brand-name {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: 20px;
    line-height: 1.05;
    letter-spacing: -0.01em;
    color: var(--paper-100);
  }
  .footer__brand-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-on-brand-muted);
    margin-top: 2px;
  }
  .footer__est {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-on-brand-muted);
    letter-spacing: 0.08em;
    text-align: right;
  }

  @media (max-width: 860px) {
    .footer__cta {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .footer__cta-actions { justify-content: flex-start; }
    .footer__title { font-size: 28px; }
  }
  @media (max-width: 560px) {
    .footer__bottom {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
    }
    .footer__est { margin-left: 0; text-align: left; }
  }
</style>
