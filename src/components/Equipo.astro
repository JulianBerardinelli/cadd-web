---
import Card from './ui/Card.astro';

// NOTA (del handoff): los nombres de archivo NO coinciden con la persona.
// El retrato de Germán E. Campisi es `christian-berardinelli.jpeg` y el de
// Christian Berardinelli es `german-campisi.jpeg`. Mantener este mapeo.
const team = [
  { name: 'Germán E. Campisi', role: 'Co-Director General', photo: 'christian-berardinelli.jpeg' },
  { name: 'Christian Berardinelli', role: 'Relaciones Institucionales y Alianzas', photo: 'german-campisi.jpeg' },
  { name: 'Dalma Varela', role: 'Gestión Institucional y Actas', photo: 'dalma-varela.jpeg' },
  { name: 'Julieta Navarro Potts', role: 'Coordinación de Relaciones Internacionales', photo: 'julieta-navarro.jpeg' },
  { name: 'Ignacio Ibáñez', role: 'Consejo Consultivo / Asesor Técnico', photo: 'ignacio-ibanez.jpeg' },
];
---

<section id="equipo" class="section equipo">
  <div class="container">
    <div class="section-head" data-reveal>
      <span class="eyebrow">¿Quiénes somos?</span>
      <h2>Conducción multidisciplinaria</h2>
      <p>
        Un equipo que equilibra representación institucional, relaciones
        internacionales y asistencia técnica de alto nivel.
      </p>
    </div>

    <div class="equipo__grid">
      {
        team.map((m, i) => (
          <div class="team-item" data-reveal data-stagger={i}>
            <Card hover padding="0" fill>
              <div class="team-card__media">
                <img src={`/team/${m.photo}`} alt={m.name} width="240" height="240" loading="lazy" />
              </div>
              <div class="team-card__text">
                <div class="team-card__name">{m.name}</div>
                <div class="team-card__role">{m.role}</div>
              </div>
            </Card>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .equipo { background: var(--surface-sunken); }

  .equipo__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
  }
  .team-item { display: flex; }

  .team-card__media {
    aspect-ratio: 1 / 1;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--midnight-700);
  }
  .team-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-standard);
  }
  .team-item:hover .team-card__media img { transform: scale(1.06); }

  .team-card__text {
    padding: 14px 16px 18px;
    flex: 1 0 auto;
  }
  .team-card__name {
    font-family: var(--font-serif);
    font-weight: var(--weight-semibold);
    font-size: 16px;
    color: var(--text-strong);
    line-height: 1.2;
  }
  .team-card__role {
    font-size: 12.5px;
    line-height: 1.4;
    color: var(--text-muted);
    margin-top: 5px;
  }

  @media (max-width: 1024px) {
    .equipo__grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 680px) {
    .equipo__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 420px) {
    .equipo__grid { grid-template-columns: 1fr; }
  }
</style>
