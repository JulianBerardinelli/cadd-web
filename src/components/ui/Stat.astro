---
interface Props {
  eyebrow: string;
  value: string;
  label: string;
  accent?: string;
}

const { eyebrow, value, label, accent = 'var(--gold-400)' } = Astro.props;
---

<div class="stat">
  <span class="stat__eyebrow">{eyebrow}</span>
  <span class="stat__value tnum" style={`color:${accent}`}>{value}</span>
  <span class="stat__label">{label}</span>
</div>

<style>
  .stat {
    display: flex;
    flex-direction: column;
  }
  .stat__eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-eyebrow);
    text-transform: uppercase;
    color: var(--text-on-brand-muted);
  }
  .stat__value {
    font-family: var(--font-mono);
    font-size: 34px;
    font-weight: var(--weight-semibold);
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-top: 6px;
  }
  .stat__label {
    font-size: 13px;
    line-height: 1.35;
    color: var(--text-on-brand-muted);
    margin-top: 4px;
  }
</style>
