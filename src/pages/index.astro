---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Mission from '../components/Mission.astro';
import Objetivos from '../components/Objetivos.astro';
import Aliados from '../components/Aliados.astro';
import Equipo from '../components/Equipo.astro';
import Plan from '../components/Plan.astro';
import Footer from '../components/Footer.astro';
import ContactModal from '../components/ContactModal.astro';
---

<Base>
  <div id="top"></div>
  <Header />
  <main>
    <Hero />
    <Mission />
    <Objetivos />
    <Aliados />
    <Equipo />
    <Plan />
  </main>
  <Footer />
  <ContactModal />
</Base>

<script>
  // Reveal por scroll con IntersectionObserver. El estado oculto lo aplica
  // CSS solo cuando <html> tiene .reveal-js (fijado por un script inline en
  // el <head>). Si no hay JS o hay reduce-motion, el contenido queda visible.
  const root = document.documentElement;
  const items = Array.from(document.querySelectorAll<HTMLElement>('[data-reveal]'));

  if (root.classList.contains('reveal-js') && 'IntersectionObserver' in window && items.length) {
    const io = new IntersectionObserver(
      (entries, obs) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          const el = entry.target as HTMLElement;
          const stagger = parseInt(el.getAttribute('data-stagger') || '0', 10) || 0;
          el.style.transitionDelay = stagger * 90 + 'ms';
          el.classList.add('is-visible');
          obs.unobserve(el);
        });
      },
      { threshold: 0.1, rootMargin: '0px 0px -6% 0px' }
    );

    items.forEach((el) => io.observe(el));

    // Fallback de seguridad: si algo falla, revela todo tras un tiempo.
    window.setTimeout(() => {
      items.forEach((el) => el.classList.add('is-visible'));
    }, 2500);
  } else {
    // reduce-motion o sin soporte: asegurar visibilidad.
    items.forEach((el) => el.classList.add('is-visible'));
  }
</script>
