---
import '../styles/tokens.css';
import '../styles/app.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'CADD — Consejo Argentino de Diplomacia Deportiva',
  description = 'El Consejo Argentino de Diplomacia Deportiva es un nexo institucional, técnico y neutral que vincula al cuerpo diplomático acreditado en Argentina con el ecosistema del deporte, la academia y la gestión social.',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const ogImage = new URL('/imagery/hero-handshake.png', Astro.site ?? Astro.url).href;
---

<!doctype html>
<html lang="es-AR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#08172b" />

    <link rel="icon" type="image/svg+xml" href="/logo/cadd-emblem.svg" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Consejo Argentino de Diplomacia Deportiva" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="es_AR" />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Webfonts: Spectral (serif) · Archivo (sans) · IBM Plex Mono -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Archivo:wght@400;500;600;700;800&family=IBM+Plex+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!-- Habilita el estado oculto del reveal por scroll antes de pintar,
         solo si el usuario no pidió reduce-motion (progressive enhancement). -->
    <script is:inline>
      (function () {
        try {
          if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
            document.documentElement.classList.add('reveal-js');
          }
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
